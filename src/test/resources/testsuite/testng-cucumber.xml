<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Cucumber BDD Test Suite -->
<!-- Run: mvn test -Pcucumber -->

<suite name="MyDemoApp Cucumber Suite"
       verbose="2"
       thread-count="1"
       parallel="none">

    <parameter name="platform" value="android"/>

    <listeners>
        <listener class-name=
                          "io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Android BDD Tests">
        <classes>
            <class name=
                           "com.framework.runners.CucumberRunner"/>
        </classes>
    </test>

</suite>