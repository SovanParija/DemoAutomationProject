<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MyDemoApp Android Suite"
       verbose="2"
       thread-count="1"
       parallel="none">

    <parameter name="platform" value="android"/>

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Android Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.framework.testscommon.MDA_1234_ValidLoginTest"/>
        </classes>
    </test>

</suite>