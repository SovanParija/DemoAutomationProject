<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- API Test Suite            -->
<!-- Run: mvn test -Papi       -->

<suite name="REST API Suite"
       verbose="2"
       thread-count="1"
       parallel="none">

    <listeners>
        <listener class-name=
                          "io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="API Tests">
        <classes>
            <class name="com.framework.api.tests.LoginAPITest"/>
        </classes>
    </test>

</suite>